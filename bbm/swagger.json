          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "userType": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "firstName": "John",
                "lastName": "Doe",
                "email": "john@example.com",
                "userType": "Individual"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/user/update-professional-profile": {
      "put": {
        "summary": "Update professional profile",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "workExperience": {
                    "type": "string"
                  },
                  "salaryExpectations": {
                    "type": "string"
                  },
                  "payStory": {
                    "type": "string"
                  },
                  "certifications": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "skills": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "language": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "education": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "workExperience": "5 years at Company X",
                "salaryExpectations": "$100,000",
                "payStory": "Started at $50k, now at $100k",
                "certifications": [
                  "AWS Certified",
                  "PMP"
                ],
                "skills": [
                  "JavaScript",
                  "Node.js"
                ],
                "language": [
                  "English",
                  "Spanish"
                ],
                "education": "BSc Computer Science"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Professional profile updated"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
